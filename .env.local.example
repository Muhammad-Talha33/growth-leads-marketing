# ──────────────────────────────────────────────────────────
# Growth Leads Marketing — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# Add these to Vercel dashboard / CLI for production.
# NEVER commit .env.local to git.

# Get your free key at https://web3forms.com
# Enter growthleadsmarketing@gmail.com → confirm email → copy key
# NEXT_PUBLIC_ prefix is required — makes the key available in the browser
NEXT_PUBLIC_WEB3FORMS_KEY=your-access-key-here
