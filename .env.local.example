# ──────────────────────────────────────────────
# Growth Leads Marketing — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Gmail address used to SEND the email (must have App Password enabled)
EMAIL_USER=your-gmail@gmail.com

# Gmail App Password (NOT your normal password)
# Generate at: Google Account → Security → 2-Step Verification → App passwords
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Email address that RECEIVES the contact form submissions
RECEIVER_EMAIL=growthleadsmarketing@gmail.com
